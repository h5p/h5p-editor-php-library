    "css-loader": "^6.10.0",
    "h5p-image-cropper": "github:h5p/h5p-image-cropper",
    "mini-css-extract-plugin": "^2.8.1",
    "sass": "^1.72.0",
    "sass-loader": "^14.1.1",
    "style-loader": "^3.3.4",
    "webpack": "^5.107.2",
    "webpack-cli": "^5.1.4",
    "zebra_datepicker": "1.9.11"
